				{
					"name": "✅ Login — Super Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.data && json.data.accessToken) {",
									"  pm.collectionVariables.set(\"ACCESS_TOKEN\", json.data.accessToken);",
									"  pm.collectionVariables.set(\"SUPER_ADMIN_TOKEN\", json.data.accessToken);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"superadmin@x-grouprestaurant.com\",\n  \"password\": \"SuperAdmin@123\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/auth/login",
							"host": ["{{BASE_URL}}"],
							"path": ["auth", "login"]
						}
					}
				},
