model GuestFeedback {
  id         Int      @id @default(autoincrement())
  feedbackId String?  @map("feedback_id")
  branchId   Int      @map("branch_id")
  guestName  String   @map("guest_name")
  contact    String
  foodRating     Int? @map("food_rating")
  serviceRating  Int? @map("service_rating")
  environmentRating Int? @map("environment_rating")
  eventRating     Int? @map("event_rating")
  overallRating   Int? @map("overall_rating")
  heardAbout HeardAbout? @map("heard_about")
  ageGroup   AgeGroup? @map("age_group")
  opinion    String?
  submittedAt DateTime @default(now()) @map("submitted_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([feedbackId])
  @@index([branchId])
  @@index([submittedAt])
  @@index([overallRating])
  @@index([branchId, submittedAt])
  @@index([branchId, overallRating])
  @@index([overallRating, submittedAt])
  @@map("guest_feedbacks")
}